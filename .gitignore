# ── User data — do not commit, even in testing ──────────────────────────────
# Account files + fluency profiles are real (if test) user data and
# credentials. Keep the folder in git, ignore its contents.
users/*
!users/.gitkeep

# ── Secrets ───────────────────────────────────────────────────────────────
.streamlit/secrets.toml
.env
.env.*

# ── Model / dataset caches ───────────────────────────────────────────────
# Confirmed against paths.py: ALL runtime caches (NLTK data, Hugging Face /
# CrisperWhisper weights ~3.2GB, sentence-transformers, torch, language_tool)
# are rerouted to this single project-local folder. Ignoring .cache/ alone
# is sufficient — nothing escapes to a system-level cache dir.
.cache/

# Stray model/weight files, in case anything is ever exported outside .cache/
*.safetensors
*.bin
*.pt
*.onnx
*.gguf

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# ── Virtual environments ─────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Benchmark clips ─────────────────────────────────────────────────────────
# Throwaway synthetic clips and (later) real recordings used by
# profiling/benchmark_asr.py. Audio is large and/or real voice data — keep the
# folder in git, ignore its contents.
benchmark_clips/*
!benchmark_clips/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────
*.log

# ── OS / editor noise ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
